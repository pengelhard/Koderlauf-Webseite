# Kopie nach .env.local – keine echten Secrets hier eintragen (diese Datei kann ins Repo).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Feedback-Formular: direkter SMTP-Versand (ohne Resend & Co.)
# Beispiel Hetzner „your-server“: Host wörtlich mail.your-server.de, Port 587 (STARTTLS) oder 465 (SSL)
SMTP_HOST=mail.your-server.de
SMTP_PORT=587
# Bei Port 465 automatisch SSL; sonst optional erzwingen:
# SMTP_SECURE=true
SMTP_USER=info@koderlauf.de
SMTP_PASS=
# Optional; Standard: „Koderlauf Website <SMTP_USER>“
# SMTP_FROM=Koderlauf Website <info@koderlauf.de>

# Nur npm run dev: Test-Zustellung an andere Adresse
# FEEDBACK_DEV_TO=deine@adresse.de

# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_SITE_URL=
